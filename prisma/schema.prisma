// =============================================================================
// PRODUCTION-GRADE SCHEMA — Safety QR System
// FIXES: 13 total — see inline [FIX-xx] comments
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

// [FIX-01] Added url — prisma generate/migrate fails without this
datasource db {
  provider = "postgresql"
}

// =============================================================================
// SCHOOL
// =============================================================================

model School {
  id               String            @id @default(uuid())
  name             String
  address          String?
  is_active        Boolean           @default(true)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  city             String?
  code             String            @unique
  country          String            @default("IN")
  email            String?
  logo_url         String?
  phone            String?
  timezone         String            @default("Asia/Kolkata")
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  cards            Card[]
  notifications    Notification[]
  payments         Payment[]
  settings         SchoolSettings?
  users            SchoolUser[]
  students         Student[]
  subscriptions    Subscription[]
  tokens           Token[]
  tokenBatches     TokenBatch[]
  webhooks         Webhook[]
  cardTemplate     CardTemplate?
  trustedScanZones TrustedScanZone[]
  parentEditLogs   ParentEditLog[]

  @@index([code])
  @@index([is_active])
}

model SchoolSettings {
  id                         String            @id @default(uuid())
  school_id                  String            @unique
  allow_location             Boolean           @default(false)
  allow_parent_edit          Boolean           @default(true)
  scan_notifications_enabled Boolean           @default(true)
  notify_on_every_scan       Boolean           @default(false)
  scan_alert_cooldown_mins   Int               @default(60)
  token_validity_months      Int               @default(12)
  max_tokens_per_student     Int               @default(1)
  default_profile_visibility ProfileVisibility @default(PUBLIC)
  created_at                 DateTime          @default(now())
  updated_at                 DateTime          @updatedAt
  school                     School            @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

// =============================================================================
// USERS
// =============================================================================

model SchoolUser {
  id            String     @id @default(uuid())
  school_id     String
  email         String     @unique
  password_hash String
  name          String?
  role          SchoolRole
  is_active     Boolean    @default(true)
  last_login_at DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  school        School     @relation(fields: [school_id], references: [id], onDelete: Cascade)
  sessions      Session[]

  @@index([school_id])
}

model ParentUser {
  id                String          @id @default(uuid())
  email             String?         @unique
  phone             String
  phone_index       String?         @unique
  password_hash     String?
  is_phone_verified Boolean         @default(false)
  is_email_verified Boolean         @default(false)
  status            UserStatus      @default(ACTIVE)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  last_login_at     DateTime?
  deleted_at        DateTime?
  devices           ParentDevice[]
  children          ParentStudent[]
  sessions          Session[]
  editLogs          ParentEditLog[]

  @@index([phone_index])
  @@index([deleted_at])
}

// [FIX-04] platform: String → DevicePlatform enum + 3 new fields
model ParentDevice {
  id           String         @id @default(uuid())
  parent_id    String
  device_token String         @unique
  platform     DevicePlatform // [FIX-04] was String
  device_name  String?        // e.g. "iPhone 15 Pro"
  app_version  String?        // e.g. "1.2.3" — for force-upgrade logic
  is_active    Boolean        @default(true)
  last_seen_at DateTime?      // updated on every authenticated request
  created_at   DateTime       @default(now())
  parent       ParentUser     @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([parent_id])
}

model SuperAdmin {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password_hash String
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  sessions      Session[]

  @@index([email])
}

// =============================================================================
// OTP SERVICE — MSG91
// SEND:   call MSG91 → insert OtpLog (verified=false, expires_at=now+10min)
// VERIFY: hash input → match otp_hash, check attempts/expiry/flags
// RESEND: set old invalidated=true → insert new OtpLog
// =============================================================================

model OtpLog {
  id           String     @id @default(uuid())
  phone        String     // E.164 e.g. "+919876543210"
  otp_hash     String     // sha256 — NEVER store plaintext OTP
  purpose      OtpPurpose
  attempts     Int        @default(0)
  max_attempts Int        @default(5)
  verified     Boolean    @default(false)
  verified_at  DateTime?
  expires_at   DateTime   // now() + 10 minutes
  invalidated  Boolean    @default(false) // true when resend burns old OTP
  msg91_req_id String?    // for delivery status callbacks
  ip_address   String?
  created_at   DateTime   @default(now())

  @@index([phone, purpose])
  @@index([expires_at])
  @@index([msg91_req_id])
}

// =============================================================================
// STUDENTS
// =============================================================================

model Student {
  id              String            @id @default(uuid())
  school_id       String
  class           String?
  photo_url       String?
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  deleted_at      DateTime?
  dob_encrypted   String?
  first_name      String
  last_name       String?
  section         String?
  cards           Card[]
  cardVisibility  CardVisibility?   // [FIX-05a]
  editLogs        ParentEditLog[]   // [FIX-05b]
  emergency       EmergencyProfile?
  locationConsent LocationConsent?
  locationEvents  LocationEvent[]
  notifications   Notification[]
  parents         ParentStudent[]
  school          School            @relation(fields: [school_id], references: [id], onDelete: Cascade)
  tokens          Token[]

  @@index([school_id])
  @@index([school_id, is_active])
  @@index([deleted_at])
}

model ParentStudent {
  id           String     @id @default(uuid())
  parent_id    String
  student_id   String
  relationship String?
  is_primary   Boolean    @default(false)
  created_at   DateTime   @default(now())
  parent       ParentUser @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, student_id])
  @@index([student_id])
  @@index([parent_id])
}

// =============================================================================
// PARENT DIRECT EDIT — no approval flow, this is the audit trail only
// =============================================================================

model ParentEditLog {
  id          String         @id @default(uuid())
  school_id   String
  student_id  String
  parent_id   String
  field_group ParentEditType
  old_value   Json?
  new_value   Json
  ip_address  String?
  created_at  DateTime       @default(now())
  school      School         @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student     Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)
  parent      ParentUser     @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([parent_id])
  @@index([school_id])
  @@index([created_at])
  @@index([field_group])
}

// =============================================================================
// CARD VISIBILITY
// =============================================================================

model CardVisibility {
  id                String            @id @default(uuid())
  student_id        String            @unique
  visibility        ProfileVisibility @default(PUBLIC)
  hidden_fields     String[]          @default([])
  updated_by_parent Boolean           @default(false)
  updated_at        DateTime          @updatedAt
  created_at        DateTime          @default(now())
  student           Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)
} // [FIX-13] brace was on same line as last field — syntax error

// =============================================================================
// EMERGENCY PROFILE
// =============================================================================

model EmergencyProfile {
  id                     String             @id @default(uuid())
  student_id             String             @unique
  blood_group            String?
  allergies              String?
  conditions             String?
  medications            String?
  doctor_name            String?
  doctor_phone_encrypted String?            // [FIX-06] was doctor_phone plaintext
  notes                  String?
  visibility             ProfileVisibility  @default(PUBLIC)
  is_visible             Boolean            @default(true)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  contacts               EmergencyContact[]
  student                Student            @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id              String           @id @default(uuid())
  profile_id      String
  name            String
  phone_encrypted String           // [FIX-07] was phone plaintext
  relationship    String?
  is_active       Boolean          @default(true)
  priority        Int
  profile         EmergencyProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([profile_id])
  @@index([profile_id, priority])
}

// =============================================================================
// TOKENS & CARDS
// =============================================================================

model Token {
  id             String              @id @default(uuid())
  school_id      String
  student_id     String?
  token_hash     String              @unique
  status         TokenStatus         @default(UNASSIGNED)
  expires_at     DateTime?
  replaced_by_id String?
  activated_at   DateTime?
  assigned_at    DateTime?
  batch_id       String?
  created_at     DateTime            @default(now())
  revoked_at     DateTime?
  cards          Card[]
  locations      LocationEvent[]
  anomalies      ScanAnomaly[]
  scans          ScanLog[]
  nonces         RegistrationNonce[]
  batch          TokenBatch?         @relation(fields: [batch_id], references: [id])
  replacedBy     Token?              @relation("TokenReplacement", fields: [replaced_by_id], references: [id])
  replacements   Token[]             @relation("TokenReplacement")
  school         School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student        Student?            @relation(fields: [student_id], references: [id])

  @@index([school_id])
  @@index([school_id, status])
  @@index([student_id])
  @@index([batch_id])
  @@index([status])
  @@index([expires_at])
}

model TokenBatch {
  id         String   @id @default(uuid())
  school_id  String
  count      Int
  created_by String?
  notes      String?
  created_at DateTime @default(now())
  tokens     Token[]
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([school_id])
}

// [FIX-10] print_status: String → PrintStatus enum
model Card {
  id           String      @id @default(uuid())
  school_id    String
  student_id   String?
  file_url     String
  created_at   DateTime    @default(now())
  card_number  String      @unique
  print_status PrintStatus @default(PENDING) // [FIX-10]
  printed_at   DateTime?
  token_id     String?
  school       School      @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student      Student?    @relation(fields: [student_id], references: [id], onDelete: Cascade)
  token        Token?      @relation(fields: [token_id], references: [id])

  @@index([school_id])
  @@index([student_id])
  @@index([token_id])
}

// =============================================================================
// SESSIONS & AUTH
// =============================================================================

// [FIX-11] Added user_agent + last_active_at + index
model Session {
  id                 String      @id @default(uuid())
  parent_user_id     String?
  school_user_id     String?
  admin_user_id      String?
  refresh_token_hash String      @unique
  device_info        String?
  user_agent         String?     // [FIX-11]
  ip_address         String?
  last_active_at     DateTime?   // [FIX-11]
  expires_at         DateTime
  created_at         DateTime    @default(now())
  parentUser         ParentUser? @relation(fields: [parent_user_id], references: [id], onDelete: Cascade)
  schoolUser         SchoolUser? @relation(fields: [school_user_id], references: [id], onDelete: Cascade)
  superAdmin         SuperAdmin? @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)

  @@index([parent_user_id])
  @@index([school_user_id])
  @@index([admin_user_id])
  @@index([expires_at])
  @@index([last_active_at]) // [FIX-11]
}

model BlacklistToken {
  expires_at DateTime
  created_at DateTime @default(now())
  token_hash String   @id

  @@index([expires_at])
}

// =============================================================================
// SCAN SYSTEM
// =============================================================================

model ScanLog {
  id               String     @id @default(uuid())
  token_id         String
  ip_address       String?
  device           String?
  created_at       DateTime   @default(now())
  ip_city          String?
  ip_country       String?
  ip_region        String?
  device_hash      String?
  scan_purpose     String?
  latitude         Float?
  longitude        Float?
  response_time_ms Int?
  result           ScanResult
  user_agent       String?
  token            Token      @relation(fields: [token_id], references: [id], onDelete: Cascade)

  @@index([token_id])
  @@index([token_id, created_at])
  @@index([created_at])
  @@index([result])
  @@index([result, created_at])
  @@index([device_hash])
}

model ScanAnomaly {
  id          String    @id @default(uuid())
  token_id    String
  reason      String
  metadata    Json?
  resolved    Boolean   @default(false)
  resolved_at DateTime?
  resolved_by String?
  created_at  DateTime  @default(now())
  token       Token     @relation(fields: [token_id], references: [id], onDelete: Cascade)

  @@index([token_id])
  @@index([resolved])
  @@index([created_at])
}

// [FIX-08] Added 2 missing indexes
model ScanRateLimit {
  id              String                  @id @default(uuid())
  identifier      String
  identifier_type RateLimitIdentifierType
  count           Int                     @default(1)
  window_start    DateTime                @default(now())
  last_hit        DateTime                @default(now())
  blocked_until   DateTime?

  @@unique([identifier, identifier_type])
  @@index([identifier, identifier_type]) // [FIX-08]
  @@index([window_start])                // [FIX-08]
  @@index([blocked_until])
}

// =============================================================================
// LOCATION
// =============================================================================

model LocationConsent {
  id           String   @id @default(uuid())
  student_id   String   @unique
  enabled      Boolean
  consented_by String?
  updated_at   DateTime @updatedAt
  student      Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

// [FIX-09] Added @@index([token_id])
model LocationEvent {
  id         String         @id @default(uuid())
  student_id String
  token_id   String?
  latitude   Float
  longitude  Float
  accuracy   Float?
  source     LocationSource @default(SCAN_TRIGGER)
  created_at DateTime       @default(now())
  student    Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)
  token      Token?         @relation(fields: [token_id], references: [id])

  @@index([student_id])
  @@index([student_id, created_at])
  @@index([token_id]) // [FIX-09]
}

// =============================================================================
// REGISTRATION
// =============================================================================

model RegistrationNonce {
  id         String   @id @default(uuid())
  nonce      String   @unique
  token_id   String
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  token      Token    @relation(fields: [token_id], references: [id], onDelete: Cascade)

  @@index([nonce])
  @@index([expires_at])
}

model TrustedScanZone {
  id         String   @id @default(uuid())
  school_id  String
  label      String
  ip_range   String?
  latitude   Float?
  longitude  Float?
  radius_m   Int      @default(200)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([school_id])
  @@index([school_id, is_active])
}

// =============================================================================
// NOTIFICATIONS, AUDIT, KEYS, WEBHOOKS, BILLING, FEATURE FLAGS, CARD TEMPLATE
// =============================================================================

model Notification {
  id         String              @id @default(uuid())
  school_id  String
  student_id String?
  parent_id  String?
  type       NotificationType
  channel    NotificationChannel
  status     NotificationStatus  @default(QUEUED)
  payload    Json?
  sent_at    DateTime?
  error      String?
  created_at DateTime            @default(now())
  school     School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student    Student?            @relation(fields: [student_id], references: [id])

  @@index([school_id])
  @@index([student_id])
  @@index([parent_id])
  @@index([status])
  @@index([created_at])
}

// [FIX-12] Added @@index([action])
model AuditLog {
  id         String    @id @default(uuid())
  action     String
  entity     String
  entity_id  String
  metadata   Json?
  created_at DateTime  @default(now())
  actor_id   String
  actor_type ActorType
  ip_address String?
  new_value  Json?
  old_value  Json?
  school_id  String?
  school     School?   @relation(fields: [school_id], references: [id])

  @@index([actor_id])
  @@index([school_id])
  @@index([entity, entity_id])
  @@index([created_at])
  @@index([action]) // [FIX-12]
}

model ApiKey {
  id           String    @id @default(uuid())
  school_id    String
  name         String
  key_hash     String    @unique
  key_prefix   String
  scopes       String[]
  last_used_at DateTime?
  expires_at   DateTime?
  revoked_at   DateTime?
  created_at   DateTime  @default(now())
  school       School    @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([school_id])
}

model Webhook {
  id          String            @id @default(uuid())
  school_id   String
  url         String
  secret_hash String
  events      String[]
  is_active   Boolean           @default(true)
  created_at  DateTime          @default(now())
  school      School            @relation(fields: [school_id], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([school_id])
}

model WebhookDelivery {
  id              String    @id @default(uuid())
  webhook_id      String
  idempotency_key String?   @unique
  event_type      String
  payload         Json
  status_code     Int?
  response        String?
  attempt         Int       @default(1)
  delivered_at    DateTime?
  created_at      DateTime  @default(now())
  webhook         Webhook   @relation(fields: [webhook_id], references: [id], onDelete: Cascade)

  @@index([webhook_id])
  @@index([webhook_id, created_at])
}

model WebhookEvent {
  id           String    @id @default(uuid())
  provider     String
  event_type   String
  payload      Json
  received_at  DateTime  @default(now())
  error        String?
  processed    Boolean   @default(false)
  processed_at DateTime?

  @@index([provider, event_type])
  @@index([processed])
}

model Subscription {
  id                   String             @id @default(uuid())
  school_id            String
  status               SubscriptionStatus @default(TRIALING)
  created_at           DateTime           @default(now())
  cancel_reason        String?
  cancelled_at         DateTime?
  current_period_end   DateTime
  current_period_start DateTime
  plan                 String
  provider             String
  provider_sub_id      String?            @unique
  trial_ends_at        DateTime?
  updated_at           DateTime           @updatedAt
  payments             Payment[]
  school               School             @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([school_id])
  @@index([status])
}

model Payment {
  id              String        @id @default(uuid())
  school_id       String
  subscription_id String
  amount          Int
  currency        String        @default("INR")
  status          PaymentStatus
  provider        String
  provider_ref    String?       @unique
  created_at      DateTime      @default(now())
  failure_reason  String?
  metadata        Json?
  school          School        @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subscription    Subscription  @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([school_id])
  @@index([subscription_id])
  @@index([status])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  metadata    Json?
  description String?
  updated_at  DateTime @updatedAt
}

model SchoolFeatureFlag {
  id        String  @id @default(uuid())
  school_id String
  key       String
  enabled   Boolean

  @@unique([school_id, key])
  @@index([school_id])
}

model CardTemplate {
  id                 String   @id @default(uuid())
  school_id          String   @unique
  logo_url           String?
  background_color   String   @default("#FFFFFF")
  primary_color      String   @default("#000000")
  text_color         String   @default("#000000")
  qr_dark_color      String   @default("#000000")
  qr_light_color     String   @default("#FFFFFF")
  cover_accent_color String   @default("#E8342A")
  cover_tagline      String?
  cards_per_sheet    Int      @default(8)
  show_student_name  Boolean  @default(true)
  show_class         Boolean  @default(true)
  show_school_name   Boolean  @default(true)
  show_photo         Boolean  @default(true)
  card_width         Int      @default(640)
  card_height        Int      @default(400)
  is_locked          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  school             School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum TokenStatus {
  UNASSIGNED
  ISSUED
  ACTIVE
  INACTIVE
  REVOKED
  EXPIRED
}

enum SchoolRole {
  ADMIN
  STAFF
  VIEWER
}

enum ScanResult {
  SUCCESS
  INVALID
  REVOKED
  EXPIRED
  INACTIVE
  RATE_LIMITED
  ERROR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  SCAN_ALERT
  SCAN_ANOMALY
  CARD_EXPIRING
  CARD_REVOKED
  CARD_REPLACED
  BILLING_ALERT
  SYSTEM
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  SUPPRESSED
}

enum ActorType {
  SUPER_ADMIN
  SCHOOL_USER
  PARENT_USER
  SYSTEM
}

enum ProfileVisibility {
  PUBLIC
  MINIMAL
  HIDDEN
}

enum LocationSource {
  SCAN_TRIGGER
  PARENT_APP
  MANUAL
}

enum ParentEditType {
  EMERGENCY_CONTACTS
  EMERGENCY_PROFILE
  STUDENT_NAME
  STUDENT_PHOTO
  PARENT_PHONE       // triggers OTP re-verify
  PARENT_EMAIL
  CARD_VISIBILITY
}

enum OtpPurpose {
  LOGIN
  PHONE_VERIFY
  CARD_BLOCK
  EMAIL_VERIFY
}

enum RateLimitIdentifierType {
  IP
  DEVICE
}

// [FIX-04] New enum — replaces String in ParentDevice.platform
enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

// [FIX-10] New enum — replaces String @default("PENDING") in Card.print_status
enum PrintStatus {
  PENDING
  PRINTED
  REPRINTED
  FAILED
}